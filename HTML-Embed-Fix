<div class="video-shell" id="video-embed-1">
  <!-- Poster: visible until user clicks -->
   <!-- Step 1/3 Replace SRC  -->
  <button type="button" class="video-poster" aria-label="Play video">
    <img
      src="https://drive.google.com/thumbnail?id=YOUR_FILE_ID&sz=w1200"
      alt="Video preview"
      loading="lazy"
    />
    <span class="video-play" aria-hidden="true"></span>
  </button>

  <!-- Iframe: no src until click (avoids blank black box on load) -->
   <!-- Step 2/3 Replace YOUR_FILE_ID -->
  <iframe
    class="video-iframe is-hidden"
    data-src="https://drive.google.com/file/d/YOUR_FILE_ID/preview"
    title="Video player"
    allow="autoplay; fullscreen"
    allowfullscreen
  ></iframe>
</div>

<style>
  .video-shell {
    width: 100%;
    max-width: 1140px;
    aspect-ratio: 4 / 3;
    border-radius: 24px;
    overflow: hidden;
    margin: 0 auto;
    background: #000;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
    position: relative;
  }

  .video-poster {
    position: absolute;
    inset: 0;
    z-index: 2;
    margin: 0;
    padding: 0;
    border: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
    background: #000;
    display: block;
  }

  .video-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 72px;
    height: 72px;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.55);
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.9);
    pointer-events: none;
  }

  .video-play::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 54%;
    transform: translate(-50%, -50%);
    border-style: solid;
    border-width: 12px 0 12px 20px;
    border-color: transparent transparent transparent #fff;
  }

  .video-poster:hover .video-play {
    background: rgba(0, 0, 0, 0.7);
  }

  .video-poster.is-hidden {
    display: none;
  }

  .video-shell iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    transform: translate(-50%, -50%);
  }

  .video-shell iframe.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .video-shell {
      max-width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 18px;
    }

    /* Step 3/3 The next transform adjusts the video position  */
    /* If crop is off-center on mobile after play, adjust this line: */
    .video-shell iframe {
      transform: translate(-50%, -55%);
    }
  }
</style>

<script>
  (function () {
    var shell = document.getElementById("video-embed-1");
    if (!shell) return;

    var poster = shell.querySelector(".video-poster");
    var iframe = shell.querySelector(".video-iframe");
    if (!poster || !iframe) return;

    function playVideo() {
      if (!iframe.src) {
        iframe.src = iframe.getAttribute("data-src");
      }
      poster.classList.add("is-hidden");
      iframe.classList.remove("is-hidden");
    }

    poster.addEventListener("click", playVideo);
  })();
</script>
